import java.util.Scanner;

class Train {
    int seatNo;
    String passengerName;
    boolean isBooked;

    Train(int seatNo) {
        this.seatNo = seatNo;
        this.isBooked = false;
    }

    void book(String name) {
        if (!isBooked) {
            passengerName = name;
            isBooked = true;
            System.out.println("Seat " + seatNo + " booked successfully!");
        } else {
            System.out.println("Seat already booked.");
        }
    }

    void cancel() {
        if (isBooked) {
            isBooked = false;
            passengerName = null;
            System.out.println("Seat " + seatNo + " cancelled.");
        } else {
            System.out.println("Seat is already empty.");
        }
    }

    void display() {
        if (isBooked) {
            System.out.println("Seat " + seatNo + " -> " + passengerName);
        } else {
            System.out.println("Seat " + seatNo + " -> Available");
        }
    }
}

public class Main {
    public static void main(String[] args) {
        Scanner sc = new Scanner(System.in);

        Train[] seats = new Train[20]; // 5 seats
        for (int i = 0; i < 20; i++) {
            seats[i] = new Train(i + 1);
        }

        int choice;

        do {
            System.out.println("\n--- Train Booking System ---");
            System.out.println("1. Book Seat");
            System.out.println("2. Cancel Seat");
            System.out.println("3. View Seats");
            System.out.println("4. Exit");
            System.out.print("Enter choice: ");

            choice = sc.nextInt();

            switch (choice) {
                case 1:
                    System.out.print("Enter seat number: ");
                    int s = sc.nextInt();
                    sc.nextLine(); // clear buffer
                    System.out.print("Enter name: ");
                    String name = sc.nextLine();
                    seats[s - 1].book(name);
                    break;

                case 2:
                    System.out.print("Enter seat number: ");
                    int c = sc.nextInt();
                    seats[c - 1].cancel();
                    break;

                case 3:
                    for (Train t : seats) {
                        t.display();
                    }
                    break;

                case 4:
                    System.out.println("Thank you!");
                    break;

                default:
                    System.out.println("Invalid choice");
            }

        } while (choice != 4);

        sc.close();
    }
}
